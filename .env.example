# Copy this file to .env and fill in values as needed for local development.
# docker compose automatically loads .env from the project root.
# Variables with defaults here can be omitted from .env unless you want to override them.

# =============================================================================
# Auth
# =============================================================================

# Set to true to disable OIDC and treat all requests as authenticated.
# Safe for local development only — never enable in production.
DEV_AUTH_BYPASS=true

# Secret used to sign session JWTs. Required when DEV_AUTH_BYPASS=false.
# Generate with: openssl rand -hex 32
SESSION_SECRET=local-dev-secret-change-in-production

# =============================================================================
# OIDC (required when DEV_AUTH_BYPASS=false)
# =============================================================================

# Base URL of your OIDC provider (e.g. https://accounts.google.com)
OIDC_ISSUER=

# OAuth2 client credentials from your provider
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Must match the redirect URI registered with your OIDC provider
OIDC_REDIRECT_URL=http://localhost:8090/auth/callback

# =============================================================================
# Poller
# =============================================================================

# How often the poller checks each cron job's status (seconds)
POLL_INTERVAL_SECONDS=30

# Minimum time between repeat alerts for the same check (minutes)
ALERT_COOLDOWN_MINUTES=60

# =============================================================================
# AWS — notifications (optional, poller only)
# =============================================================================

AWS_REGION=us-east-1

# From address for SES email alerts (must be verified in SES)
AWS_SES_FROM=

# Set to true to enable SMS alerts via SNS
AWS_SNS_SMS_ENABLED=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
